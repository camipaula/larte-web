<section class="galeria" id="galeria">
  <div class="galeria-header">
    <p class="section-tag">Nuestro trabajo</p>
    <h2>Galería <em>L'Arte</em></h2>
  </div>

  <div class="masonry">
    <div class="item-galeria tall">
      <img src="/images/g1.jpg" alt="Caballete en uso" />
    </div>
    
    <div class="item-galeria">
      <img src="/images/g2.jpg" alt="Detalle de materiales" />
    </div>
    
    <div class="item-galeria">
      <img src="/images/tripodepino.jpg" alt="Caballete de pino natural" />
    </div>
    
    <div class="item-galeria wide">
      <img src="/images/g4.jpg" alt="Pinturas y materiales" />
    </div>
    
    <div class="item-galeria">
      <img src="/images/maniqui.jpg" alt="Maniquí de madera" />
    </div>
  </div>

  <div class="galeria-cta">
    <p>¿Querés ver más productos?</p>
    <a href="https://wa.me/593987737600?text=Hola! Quiero ver más fotos del catálogo" target="_blank" class="btn-outline">
      Ver catálogo completo por WhatsApp
    </a>
  </div>
</section>

<style>
.galeria {
  background: var(--tierra);
  padding: 6rem 4rem;
  color: var(--crema);
}

.galeria-header {
  text-align: center;
  margin-bottom: 3rem;
}

.section-tag {
  font-size: 0.8rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--madera);
  margin-bottom: 0.8rem;
}

h2 {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 900;
  color: var(--crema);
}
h2 em {
  color: var(--madera);
  font-style: italic;
}

/* MASONRY GRID CON IMÁGENES AJUSTADAS */
.masonry {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-auto-rows: 220px;
  gap: 1rem;
  max-width: 1100px;
  margin: 0 auto 3rem;
}

.item-galeria {
  border-radius: 0.8rem;
  overflow: hidden; 
  background: var(--crema-dark);
}

.item-galeria img {
  width: 100%;
  height: 100%;
  object-fit: cover; 
  transition: transform 0.4s ease;
}

.item-galeria:hover img {
  transform: scale(1.05); 
}

.tall  { grid-row: span 2; }
.wide  { grid-column: span 2; }

/* CTA */
.galeria-cta {
  text-align: center;
}
.galeria-cta p {
  color: rgba(245,240,232,0.6);
  margin-bottom: 1.2rem;
  font-size: 0.95rem;
}

.btn-outline {
  display: inline-block;
  border: 1px solid var(--madera);
  color: var(--madera);
  padding: 0.85rem 2rem;
  border-radius: 999px;
  font-weight: 500;
  font-size: 0.9rem;
  transition: all 0.3s ease;
}
.btn-outline:hover {
  background: var(--madera);
  color: var(--tierra);
}

@media (max-width: 768px) {
  .galeria { padding: 4rem 1.5rem; }
  .masonry {
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: 160px;
  }
  .wide { grid-column: span 2; }
}
</style>