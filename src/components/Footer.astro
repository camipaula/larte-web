  <span class="wpp-label">¡Escríbenos!</span>
</a>

<style>
/* FOOTER */
.footer {
  background: var(--tierra);
  color: var(--crema);
  padding: 4rem 4rem 2rem;
}

.footer-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 3rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid rgba(196,154,108,0.15);
  margin-bottom: 1.5rem;
}

.logo {
  font-family: var(--font-display);
  font-size: 1.6rem;
  font-weight: 900;
  display: block;
  margin-bottom: 0.8rem;
}
.logo em { color: var(--madera); font-style: italic; }

.footer-brand p {
  font-size: 0.88rem;
  color: rgba(245,240,232,0.55);
  line-height: 1.6;
  max-width: 260px;
}

.footer-links {
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}
.footer-links a {
  font-size: 0.9rem;
  color: rgba(245,240,232,0.6);
  transition: color 0.2s;
}
.footer-links a:hover { color: var(--madera); }

.footer-contact p {
  font-size: 0.8rem;
  color: rgba(245,240,232,0.5);
  margin-bottom: 0.6rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}
.footer-wpp {
  font-size: 1rem;
  font-weight: 500;
  color: var(--madera);
  transition: color 0.2s;
}
.footer-wpp:hover { color: var(--acento); }

.footer-bottom {
  max-width: 1100px;
  margin: 0 auto;
  text-align: center;
}
.footer-bottom p {
  font-size: 0.82rem;
  color: rgba(245,240,232,0.35);
}

/* BOTÓN FLOTANTE WHATSAPP */
.wpp-float {
  position: fixed;
  bottom: 2rem;
  right: 2rem;
  background: #25D366;
  color: white;
  border-radius: 999px;
  padding: 0.85rem 1.4rem 0.85rem 1rem;
  display: flex;
  align-items: center;
  gap: 0.6rem;
  box-shadow: 0 6px 24px rgba(37,211,102,0.4);
  z-index: 999;
  transition: all 0.3s ease;
  font-weight: 500;
  font-size: 0.9rem;
}
.wpp-float:hover {
  transform: translateY(-3px) scale(1.04);
  box-shadow: 0 10px 32px rgba(37,211,102,0.5);
}
.wpp-label { white-space: nowrap; }

@media (max-width: 768px) {
  .footer { padding: 3rem 1.5rem 1.5rem; }
  .footer-inner {
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .wpp-float { bottom: 1.2rem; right: 1.2rem; }
  .wpp-label { display: none; }
  .wpp-float { padding: 1rem; border-radius: 50%; }
}
</style>