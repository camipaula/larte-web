<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="logo">L'<em>Arte</em></span>
      <p>Caballetes, lienzos y materiales de arte. Quito, Ecuador.</p>
    </div>
    <div class="footer-links">
      <a href="#productos">Productos</a>
      <a href="#galeria">Galería</a>
      <a href="#nosotros">Nosotros</a>
    </div>
    <div class="footer-contact">
      <p>¿Preguntas? Escríbenos</p>
      <a href="https://wa.me/593987737600" target="_blank" class="footer-wpp">WhatsApp →</a>
    </div>
  </div>
  <div class="footer-bottom">
    <p>© 2024 L'Arte · Hecho con ❤️ en Ecuador</p>
  </div>
</footer>

<!-- BOTÓN WHATSAPP FLOTANTE -->
<a
  href="https://wa.me/593987737600?text=Hola! Quiero información sobre sus productos"
  target="_blank"
  class="wpp-float"
  aria-label="Contactar por WhatsApp"
>
  <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
    <path d="M12 0C5.373 0 0 5.373 0 12c0 2.136.558 4.14 1.535 5.878L.057 23.269a.75.75 0 0 0 .916.916l5.36-1.476A11.953 11.953 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.722 9.722 0 0 1-4.964-1.357l-.354-.211-3.681 1.013 1.017-3.718-.229-.371A9.722 9.722 0 0 1 2.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/>
